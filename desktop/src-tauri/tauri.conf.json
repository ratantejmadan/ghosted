{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ghosted",
  "version": "0.1.0",
  "identifier": "com.ghosted.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
      "title": "ghosted",
      "width": 960,
      "height": 680,
      "minWidth": 820,
      "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
